<Window x:Class="WindowsNothIsland.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Width="750"
        Height="260">

    <Grid>
        <Border x:Name="Island"
                Background="#0F0F10"
                Width="260"
                Height="58"
                CornerRadius="0,0,18,18"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                MouseEnter="Island_MouseEnter"
                MouseLeave="Island_MouseLeave">

            <Grid Margin="16,10">

                <!-- COLLAPSED -->
                <Grid x:Name="CollapsedView">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Image x:Name="AlbumArt"
                            Width="34"
                            Height="34"
                            Stretch="UniformToFill"
                            Margin="0,0,10,0"/>

                    <StackPanel Grid.Column="1"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center">

                        <TextBlock x:Name="TitleText"
                                    Text="Nothing playing"
                                    Foreground="White"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    TextTrimming="CharacterEllipsis"/>

                        <TextBlock x:Name="ArtistText"
                                    Text=""
                                    Foreground="#A0A0A0"
                                    FontSize="11"
                                    TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <TextBlock Grid.Column="2"
                                Text="▶"
                                Foreground="#EAEAEA"
                                FontSize="18"
                                VerticalAlignment="Center"/>
                </Grid>

                <!-- EXPANDED -->
                <StackPanel x:Name="ExpandedView"
                            Visibility="Collapsed"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Margin="10">

                    <!-- LEFT -->
                    <Image x:Name="ExpandedAlbumArt"
                            Width="120"
                            Height="120"
                            Stretch="UniformToFill"
                            VerticalAlignment="Center"
                            Margin="0,0,60,0"/>

                    <!-- RIGHT -->
                    <StackPanel Width="320"
                                VerticalAlignment="Center">

                        <TextBlock x:Name="ExpandedTitle"
                                    Text="Song Name"
                                    Foreground="White"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    TextTrimming="CharacterEllipsis"/>

                        <TextBlock x:Name="ExpandedArtist"
                                    Text="Artist"
                                    Foreground="#A0A0A0"
                                    FontSize="13"
                                    Margin="0,2,0,12"/>

                        <!-- TIMELINE -->
                        <Grid Margin="0,0,0,12">

                            <Border Height="3"
                                    Background="#2C2C2E"
                                    CornerRadius="2"/>

                            <Border x:Name="ProgressBar"
                                    Height="3"
                                    Width="120"
                                    Background="White"
                                    CornerRadius="2"
                                    HorizontalAlignment="Left"/>

                            <Ellipse Width="8"
                                        Height="8"
                                        Fill="White"
                                        HorizontalAlignment="Left"
                                        Margin="120,-2,0,0"/>
                        </Grid>

                        <!-- CONTROLS -->
                        <StackPanel Orientation="Horizontal">

                            <TextBlock Text="⏮"
                                        FontSize="20"
                                        Foreground="White"
                                        Margin="0,0,15,0"/>

                            <TextBlock Text="⏯"
                                        FontSize="22"
                                        Foreground="White"
                                        Margin="0,0,15,0"/>

                            <TextBlock Text="⏭"
                                        FontSize="20"
                                        Foreground="White"/>
                        </StackPanel>

                    </StackPanel>

                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</Window>