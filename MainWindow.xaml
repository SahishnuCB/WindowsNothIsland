<Window x:Class="WindowsNothIsland.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Width="750"
        Height="260">

    <Grid>
        <Border x:Name="Island"
                Background="#0F0F10"
                Width="280"
                Height="74"
                CornerRadius="0,0,18,18"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                MouseEnter="Island_MouseEnter"
                MouseLeave="Island_MouseLeave">

            <Grid Margin="16,10">

                <!-- COLLAPSED -->
                <Grid x:Name="CollapsedView">

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                        <Image x:Name="AlbumArt"
                                Width="28"
                                Height="28"
                                Stretch="UniformToFill"
                                Margin="0,0,10,0"/>

                        <TextBlock x:Name="TitleText"
                                    Text="Nothing playing"
                                    Foreground="White"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    VerticalAlignment="Center"
                                    TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                </Grid>

                <StackPanel x:Name="ClockView"
                            Visibility="Collapsed"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                    <TextBlock x:Name="ClockTimeText"
                                Text="10:42"
                                Foreground="White"
                                FontSize="24"
                                FontWeight="SemiBold"
                                TextAlignment="Center"/>

                    <TextBlock x:Name="ClockDateText"
                                Text="Sun, Apr 26"
                                Foreground="#A0A0A0"
                                FontSize="11"
                                TextAlignment="Center"
                                Margin="0,-2,0,0"/>
                </StackPanel>

                <!-- EXPANDED -->
                <StackPanel x:Name="ExpandedView"
                            Visibility="Collapsed"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Margin="10">

                    <Image x:Name="ExpandedAlbumArt"
                            Width="120"
                            Height="120"
                            Stretch="UniformToFill"
                            VerticalAlignment="Center"
                            Margin="0,0,60,0"/>

                    <StackPanel Width="320"
                                VerticalAlignment="Center">

                        <TextBlock x:Name="ExpandedTitle"
                                    Text="Song Name"
                                    Foreground="White"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    TextTrimming="CharacterEllipsis"/>

                        <TextBlock x:Name="ExpandedArtist"
                                    Text="Artist"
                                    Foreground="#A0A0A0"
                                    FontSize="13"
                                    Margin="0,2,0,12"/>

                        <!-- TIMELINE -->
                        <StackPanel Margin="0,0,0,12">
                            <Canvas Width="320"
                                    Height="10">
                                <Border Width="320"
                                        Height="3"
                                        Background="#2C2C2E"
                                        CornerRadius="2"
                                        Canvas.Top="3"/>

                                <Border x:Name="ProgressBar"
                                        Width="0"
                                        Height="3"
                                        Background="White"
                                        CornerRadius="2"
                                        Canvas.Top="3"/>

                                <Ellipse x:Name="ProgressDot"
                                            Width="8"
                                            Height="8"
                                            Fill="White"
                                            Canvas.Left="0"
                                            Canvas.Top="0"/>
                            </Canvas>

                            <Grid Width="320"
                                    Margin="0,4,0,0">
                                <TextBlock x:Name="CurrentTimeText"
                                            Text="0:00"
                                            Foreground="#8E8E93"
                                            FontSize="10"
                                            HorizontalAlignment="Left"/>

                                <TextBlock x:Name="DurationText"
                                            Text="0:00"
                                            Foreground="#8E8E93"
                                            FontSize="10"
                                            HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>

                        <!-- CONTROLS -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">

                            <Border Width="36"
                                    Height="36"
                                    CornerRadius="18"
                                    Margin="0,0,12,0"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="PreviousButton_Click">

                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background"
                                                Value="#1C1C1E"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver"
                                                    Value="True">
                                                <Setter Property="Background"
                                                        Value="#2C2C2E"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <TextBlock Text="⏮"
                                            Foreground="White"
                                            FontSize="16"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                            </Border>

                            <Border Width="48"
                                    Height="48"
                                    CornerRadius="24"
                                    Margin="0,0,12,0"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="PlayPauseButton_Click">

                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background"
                                                Value="White"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver"
                                                    Value="True">
                                                <Setter Property="Background"
                                                        Value="#E5E5E5"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <TextBlock x:Name="PlayPauseIcon"
                                            Text="⏯"
                                            Foreground="Black"
                                            FontSize="20"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                            </Border>

                            <Border Width="36"
                                    Height="36"
                                    CornerRadius="18"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="NextButton_Click">

                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background"
                                                Value="#1C1C1E"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver"
                                                    Value="True">
                                                <Setter Property="Background"
                                                        Value="#2C2C2E"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <TextBlock Text="⏭"
                                            Foreground="White"
                                            FontSize="16"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                            </Border>

                        </StackPanel>
                    </StackPanel>
                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</Window>