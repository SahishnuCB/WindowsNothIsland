<Window x:Class="WindowsNothIsland.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Width="750"
        Height="260">

    <Grid>

        <tb:TaskbarIcon x:Name="TrayIcon"
                        xmlns:tb="http://www.hardcodet.net/taskbar"
                        IconSource="icon.ico"
                        ToolTipText="Windows Noth Island"
                        TrayMouseDoubleClick="Tray_ShowHide"
                        Visibility="Visible">

            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Show / Hide"
                                Click="Tray_ShowHide"/>
                    <MenuItem Header="Exit"
                                Click="Tray_Exit"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <Border x:Name="Island"
                Background="#0F0F10"
                Width="280"
                Height="74"
                CornerRadius="0,0,18,18"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                MouseEnter="Island_MouseEnter"
                MouseLeave="Island_MouseLeave"
                MouseWheel="Island_MouseWheel"
                MouseLeftButtonDown="Island_MouseLeftButtonDown"
                MouseMove="Island_MouseMove"
                MouseLeftButtonUp="Island_MouseLeftButtonUp">

            <Grid>

                <!-- MEDIA COLLAPSED -->
                <Grid x:Name="CollapsedView"
                        Margin="16,10">

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="240">

                        <Border Width="32"
                                Height="32"
                                CornerRadius="6"
                                ClipToBounds="True"
                                Margin="0,0,10,0">

                            <Image x:Name="AlbumArt"
                                    Stretch="UniformToFill"/>
                        </Border>

                        <TextBlock x:Name="TitleText"
                                    Text="Nothing playing"
                                    Foreground="White"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    VerticalAlignment="Center"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="NoWrap"
                                    Width="160"/>
                    </StackPanel>
                </Grid>

                <!-- CLOCK COLLAPSED -->
                <StackPanel x:Name="ClockView"
                            Visibility="Collapsed"
                            Margin="16,10"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                    <TextBlock x:Name="ClockTimeText"
                                Text="14:32"
                                Foreground="White"
                                FontSize="24"
                                FontWeight="SemiBold"
                                TextAlignment="Center"/>

                    <TextBlock x:Name="ClockDateText"
                                Text="Sun, Apr 26"
                                Foreground="#A0A0A0"
                                FontSize="11"
                                TextAlignment="Center"
                                Margin="0,-2,0,0"/>
                </StackPanel>

                <!-- CLOCK EXPANDED -->
                <StackPanel x:Name="ClockExpandedView"
                            Visibility="Collapsed"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                    <Canvas Width="130"
                            Height="130"
                            Margin="0,0,55,0">

                        <Ellipse Width="130"
                                    Height="130"
                                    Stroke="#2C2C2E"
                                    StrokeThickness="2"
                                    Fill="#121214"/>

                        <Line X1="65"
                                Y1="65"
                                X2="65"
                                Y2="34"
                                Stroke="White"
                                StrokeThickness="4"
                                StrokeStartLineCap="Round"
                                StrokeEndLineCap="Round">
                            <Line.RenderTransform>
                                <RotateTransform x:Name="HourHandRotate"
                                                    CenterX="65"
                                                    CenterY="65"/>
                            </Line.RenderTransform>
                        </Line>

                        <Line X1="65"
                                Y1="65"
                                X2="65"
                                Y2="20"
                                Stroke="White"
                                StrokeThickness="3"
                                StrokeStartLineCap="Round"
                                StrokeEndLineCap="Round">
                            <Line.RenderTransform>
                                <RotateTransform x:Name="MinuteHandRotate"
                                                    CenterX="65"
                                                    CenterY="65"/>
                            </Line.RenderTransform>
                        </Line>

                        <Line X1="65"
                                Y1="65"
                                X2="65"
                                Y2="16"
                                Stroke="#FF453A"
                                StrokeThickness="1.5"
                                StrokeStartLineCap="Round"
                                StrokeEndLineCap="Round">
                            <Line.RenderTransform>
                                <RotateTransform x:Name="SecondHandRotate"
                                                    CenterX="65"
                                                    CenterY="65"/>
                            </Line.RenderTransform>
                        </Line>

                        <Ellipse Width="7"
                                    Height="7"
                                    Fill="White"
                                    Canvas.Left="61.5"
                                    Canvas.Top="61.5"/>
                    </Canvas>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="ClockDayExpandedText"
                                    Text="Sunday"
                                    Foreground="White"
                                    FontSize="24"
                                    FontWeight="SemiBold"/>

                        <TextBlock x:Name="ClockFullDateExpandedText"
                                    Text="Apr 26, 2026"
                                    Foreground="#A0A0A0"
                                    FontSize="15"
                                    Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- MEDIA EXPANDED -->
                <Border x:Name="ExpandedView"
                        Visibility="Collapsed"
                        CornerRadius="0,0,18,18"
                        Background="#0F0F10">

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Margin="26,0">

                        <Image x:Name="ExpandedAlbumArt"
                                Width="120"
                                Height="120"
                                Stretch="UniformToFill"
                                VerticalAlignment="Center"
                                Margin="0,0,60,0">

                            <Image.Clip>
                                <RectangleGeometry Rect="0,0,120,120"
                                                    RadiusX="12"
                                                    RadiusY="12"/>
                            </Image.Clip>

                        </Image>

                        <StackPanel Width="320"
                                    VerticalAlignment="Center">

                            <TextBlock x:Name="ExpandedTitle"
                                        Text="Song Name"
                                        Foreground="White"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        TextTrimming="CharacterEllipsis"/>

                            <TextBlock x:Name="ExpandedArtist"
                                        Text="Artist"
                                        Foreground="#D0D0D0"
                                        FontSize="13"
                                        Margin="0,2,0,12"/>

                            <StackPanel Margin="0,0,0,12">
                                <Canvas x:Name="TimelineCanvas"
                                        Width="320"
                                        Height="10"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="Timeline_MouseLeftButtonDown"
                                        MouseMove="Timeline_MouseMove"
                                        MouseLeftButtonUp="Timeline_MouseLeftButtonUp">

                                    <Border Width="320"
                                            Height="3"
                                            Background="#2C2C2E"
                                            CornerRadius="2"
                                            Canvas.Top="3"/>

                                    <Border x:Name="ProgressBar"
                                            Width="0"
                                            Height="3"
                                            Background="White"
                                            CornerRadius="2"
                                            Canvas.Top="3"/>

                                    <Ellipse x:Name="ProgressDot"
                                                Width="8"
                                                Height="8"
                                                Fill="White"
                                                Canvas.Left="0"
                                                Canvas.Top="0"/>
                                </Canvas>

                                <Grid Width="320"
                                        Margin="0,4,0,0">

                                    <TextBlock x:Name="CurrentTimeText"
                                                Text="0:00"
                                                Foreground="#D0D0D0"
                                                FontSize="10"
                                                HorizontalAlignment="Left"/>

                                    <TextBlock x:Name="DurationText"
                                                Text="0:00"
                                                Foreground="#D0D0D0"
                                                FontSize="10"
                                                HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>

                            <!-- Play/Pause Button -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">

                                <Border Width="36"
                                        Height="36"
                                        CornerRadius="18"
                                        Margin="0,0,12,0"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="PreviousButton_Click">

                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"
                                                    Value="#1C1C1E"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver"
                                                            Value="True">
                                                    <Setter Property="Background"
                                                            Value="#2C2C2E"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <TextBlock Text="⏮"
                                                Foreground="White"
                                                FontSize="16"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                                </Border>

                                <Border Width="48"
                                        Height="48"
                                        CornerRadius="24"
                                        Margin="0,0,12,0"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="PlayPauseButton_Click">

                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"
                                                    Value="White"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver"
                                                            Value="True">
                                                    <Setter Property="Background"
                                                            Value="#E5E5E5"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <TextBlock x:Name="PlayPauseIcon"
                                                Text="⏯"
                                                Foreground="Black"
                                                FontSize="20"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                                </Border>

                                <Border Width="36"
                                        Height="36"
                                        CornerRadius="18"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="NextButton_Click">

                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"
                                                    Value="#1C1C1E"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver"
                                                            Value="True">
                                                    <Setter Property="Background"
                                                            Value="#2C2C2E"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <TextBlock Text="⏭"
                                                Foreground="White"
                                                FontSize="16"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>
    </Grid>
</Window>