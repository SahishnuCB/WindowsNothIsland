<Window x:Class="WindowsNothIsland.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Width="650"
        Height="230">

    <Grid>
        <Border x:Name="Island"
                Background="#0F0F10"
                Width="260"
            Height="58"
            CornerRadius="0,0,18,18"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                MouseEnter="Island_MouseEnter"
                MouseLeave="Island_MouseLeave">

            <Grid Margin="16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Album Art -->
                <Rectangle Width="34"
                            Height="34"
                            Fill="#2C2C2E"
                            RadiusX="8"
                            RadiusY="8"
                            VerticalAlignment="Center"/>

                <!-- Text -->
                <StackPanel Grid.Column="1"
                            Margin="12,0"
                            VerticalAlignment="Center">

                    <TextBlock x:Name="TitleText"
                                Text="Nothing playing"
                                Foreground="White"
                                FontSize="13"
                                FontWeight="SemiBold"
                                TextTrimming="CharacterEllipsis"/>

                    <TextBlock x:Name="ArtistText"
                                Text=""
                                Foreground="#A0A0A0"
                                FontSize="11"
                                TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- Play Button -->
                <TextBlock Grid.Column="2"
                            Text="▶"
                            Foreground="#EAEAEA"
                            FontSize="18"
                            VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>